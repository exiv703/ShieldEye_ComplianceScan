# ShieldEye-ComplianceScan v0.1.0-alpha — Copy to .env and customize
SHIELDEYE_DB_URL=postgresql://user:pass@host:5432/db # Required: PostgreSQL DSN for scan persistence # nosec B106,B107 # pragma: allowlist secret
SHIELDEYE_REDIS_URL=redis://localhost:6379/0 # Optional: Redis for queue/idempotency cache
COMPLIANCE_BENCHMARKS_ENABLED=true # MVP: Enable CIS/PCI-DSS/SOC2 benchmark execution
ALLOW_INSECURE_TARGETS=false # MVP: Permit TLS-bypass scans (internal targets only) ⚠️
ENABLE_REMEDIATION_SNIPPETS=true # MVP: Include copy-paste fix commands in reports
SHIELDEYE_TIMEOUT=300 # Why 600s max? Balances scan completeness vs UX timeout

# Impact: A standardized env template improves reproducibility, reduces misconfiguration risk, and supports audit-ready compliance rollouts.
