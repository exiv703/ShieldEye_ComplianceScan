# ShieldEye-ComplianceScan v0.2.0-beta — Copy to .env and customize
SHIELDEYE_DB_URL=postgresql://user:pass@host:5432/db # Required: PostgreSQL DSN for scan persistence # nosec B106,B107 # pragma: allowlist secret
SHIELDEYE_REDIS_URL=redis://localhost:6379/0 # Optional: Redis for queue/idempotency cache
COMPLIANCE_BENCHMARKS_ENABLED=true # MVP: Enable CIS/PCI-DSS/SOC2 benchmark execution
ALLOW_INSECURE_TARGETS=false # MVP: Permit TLS-bypass scans (internal targets only) ⚠️
ENABLE_REMEDIATION_SNIPPETS=true # MVP: Include copy-paste fix commands in reports

# Phase 2 additions — copy to .env and customize
ENABLE_CORE_INTEGRATION=true # MVP: Import scan results from ShieldEye-Core instance
# Why separate flags? Enables gradual rollout of external dependencies
ENABLE_SURFACESCAN_INTEGRATION=true # MVP: Correlate surface findings to compliance controls
# Why separate flags? Enables gradual rollout of external dependencies
ENABLE_SARIF_EXPORT=false # MVP-light: Optional SARIF output for GRC platform import
# Why optional? SARIF adds complexity; MVP focuses on JSON + human-readable first
REMEDIATION_SNIPPET_TIMEOUT=30 # Why 30s? Balances snippet generation speed vs complex template rendering

SHIELDEYE_TIMEOUT=300 # Why 600s max? Balances scan completeness vs UX timeout

# Impact: Documented, versioned env templates reduce onboarding friction and prevent silent misconfiguration of SSRF-sensitive integration flags.
