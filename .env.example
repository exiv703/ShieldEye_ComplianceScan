# ShieldEye-ComplianceScan v1.0.0 — Copy to .env and customize

# Core persistence and runtime paths
SHIELDEYE_DB_URL=postgresql://user:pass@host:5432/db # Required: primary PostgreSQL DSN for scan persistence # nosec B106,B107 # pragma: allowlist secret
SHIELDEYE_REDIS_URL=redis://localhost:6379/0 # Why: enables distributed idempotency, queue coordination, and alert-state caching in multi-worker deployments
SHIELDEYE_DB_PATH=$HOME/.shieldeye/scans.db # Why: local SQLite fallback/history location for CLI and desktop workflows
SHIELDEYE_LOG_DIR=$HOME/.shieldeye/logs # Why: centralizes structured logs for audit and troubleshooting
SHIELDEYE_REPORTS_DIR=$HOME/.shieldeye/reports # Why: deterministic report output path for automation

# Scanner defaults and transport controls
SHIELDEYE_TIMEOUT=300 # Why: bounded scan duration to reduce hung jobs while allowing deep checks
SHIELDEYE_MAX_PAGES=100 # Why: controls crawl breadth to avoid unbounded scans in production
SHIELDEYE_MAX_DEPTH=3 # Why: limits crawl recursion to keep scans predictable and repeatable
SHIELDEYE_VERIFY_SSL=true # Why: secure-by-default certificate validation for outbound scanner requests
SHIELDEYE_ALLOW_INSECURE_TARGETS=false # Why: explicit opt-in for internal/testing targets with invalid TLS only
SHIELDEYE_USER_AGENT=ShieldEye-ComplianceScan/1.0.0 # Why: identifiable scanner traffic for gateway and SIEM attribution

# Phase 1 baseline feature flags
COMPLIANCE_BENCHMARKS_ENABLED=true # Why: enable CIS/PCI-DSS/SOC2/GDPR benchmark execution in compliance pipeline
ENABLE_REMEDIATION_SNIPPETS=true # Why: include copy-paste remediation commands in generated reports

# Phase 2 integration and reporting flags
ENABLE_CORE_INTEGRATION=true # Why: allow ingestion from ShieldEye-Core as an upstream source
ENABLE_SURFACESCAN_INTEGRATION=true # Why: correlate SurfaceScan findings to compliance controls
ENABLE_SARIF_EXPORT=false # Why: optional SARIF output for ecosystems that require SARIF ingestion
REMEDIATION_SNIPPET_TIMEOUT=30 # Why: caps remediation template rendering latency in report generation

# Phase 3 resilience and observability flags
SHIELDEYE_RATE_LIMIT=true # Why: apply per-target guardrails to protect upstream dependencies
SHIELDEYE_ENABLE_PROMETHEUS_EXPORT=false # Why: keep metrics endpoint off until secured scrape path is provisioned
SHIELDEYE_ENABLE_OPENTELEMETRY=false # Why: avoid trace emission overhead unless OTEL pipeline is configured
ENABLE_ML_CORRELATION=false # Why: default to deterministic heuristic correlation until model ops are validated
ML_CORRELATION_CONFIDENCE_THRESHOLD=0.75 # Why: balanced ML acceptance threshold before environment-specific calibration

# Phase 4/5 enterprise workflow controls
SHIELDEYE_ENABLE_INTERACTIVE_REMEDIATION=false # Why: optional guided remediation workflow for teams that need wizard-driven fixes
SHIELDEYE_ENABLE_POLICY_MANAGEMENT=false # Why: optional policy management workflow for governance-heavy environments
SHIELDEYE_ENABLE_REALTIME_MONITORING=false # Why: optional real-time monitoring to avoid WebSocket/stream overhead by default
SHIELDEYE_ALERT_WINDOW_SECONDS=300 # Why: defines alert aggregation window to reduce noisy real-time notifications
ENABLE_POLICY_CACHE=true # Why: caches policy validation artifacts to reduce repeated parse/validation overhead

# GRC export controls (legacy + namespaced compatibility)
ENABLE_GRC_EXPORT=false # Why: enables GRC payload generation in JSON export pipeline
SHIELDEYE_ENABLE_GRC_EXPORT=false # Why: namespaced compatibility flag for config-driven GRC export toggle
GRC_PLATFORM=servicenow # Why: selects payload formatting profile for target GRC system
SHIELDEYE_GRC_PLATFORM=servicenow # Why: namespaced compatibility for GRC platform selection
GRC_WEBHOOK_URL= # Why: optional webhook destination for downstream GRC sync workflows
SHIELDEYE_GRC_WEBHOOK_URL= # Why: namespaced compatibility for webhook endpoint configuration

# Optional platform-specific GRC credentials (set only when corresponding platform is used)
GRC_SERVICENOW_INSTANCE_URL= # Why: required for ServiceNow API payload routing
GRC_SERVICENOW_API_KEY= # Why: authentication for ServiceNow export transport
GRC_DRATA_WORKSPACE_ID= # Why: required for Drata workspace scoping
GRC_DRATA_API_KEY= # Why: authentication for Drata export transport
GRC_VANTA_TENANT_ID= # Why: required for Vanta tenant scoping
GRC_VANTA_API_KEY= # Why: authentication for Vanta export transport

# Logging and bootstrap controls
SHIELDEYE_LOG_LEVEL=INFO # Why: baseline verbosity for production incident triage
SHIELDEYE_STRUCTURED_LOGS=true # Why: machine-parseable logs for SIEM ingestion and audit trails
SHIELDEYE_INITIAL_ADMIN_PASSWORD= # Why: optional bootstrap credential to avoid random default password generation

# Impact: Documented feature flags enable predictable, auditable production deployments.
